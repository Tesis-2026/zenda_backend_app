<?xml version="1.0" encoding="utf-8"?>
<!--
  Azure App Service (Windows) runs Node behind IIS via iisnode. Without this
  file IIS serves its default site (403 at /, 404 elsewhere) and the NestJS
  process is never invoked. This routes every non-static request to the
  compiled entry point produced by `npm run build`.

  NOTE: `nest build` emits to dist/src/main.js (not dist/main.js) because the
  compilation also includes prisma/*.ts, so TypeScript keeps the src/ subtree.
-->
<configuration>
  <system.webServer>
    <webSocket enabled="false" />

    <handlers>
      <!-- Hand all traffic for the entry file to the iisnode module. -->
      <add name="iisnode" path="dist/src/main.js" verb="*" modules="iisnode" />
    </handlers>

    <rewrite>
      <rules>
        <!-- Let iisnode's own debug UI through untouched. -->
        <rule name="iisnode-debug" patternSyntax="ECMAScript" stopProcessing="true">
          <match url="^dist/src/main.js\/debug[\/]?" />
        </rule>

        <!-- Everything else that is not a real file on disk goes to Node. -->
        <rule name="DynamicContent">
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="dist/src/main.js" />
        </rule>
      </rules>
    </rewrite>

    <!--
      iisnode must be given an EXPLICIT path to node.exe: the IIS worker (w3wp) PATH
      does not include the Node dir, and the only modern node.exe on the host lives in
      a versioned folder (there is none at the default C:\Program Files\nodejs\node.exe).
      Use the 8.3 SHORT path (PROGRA~1) so the value has no spaces: a quoted path
      ("...\node.exe") is passed with the literal quotes to CreateProcess, which then
      cannot find the file and iisnode fails with 0x2 (FILE_NOT_FOUND) -> HTTP 500.1002.
      The short path is space-free, needs no quotes, and resolves cleanly.
      This versioned path must match the WEBSITE_NODE_DEFAULT_VERSION app setting
      (currently 22.22.2); update both together when bumping the Node version.
    -->
    <iisnode nodeProcessCommandLine="C:\PROGRA~1\nodejs\22.22.2\node.exe" loggingEnabled="true" devErrorsEnabled="false" />

    <!-- Let NestJS render its own error bodies instead of IIS replacing them. -->
    <httpErrors existingResponse="PassThrough" />
  </system.webServer>
</configuration>
