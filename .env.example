# ─────────────────────────────────────────────────────────────────
# Zenda Backend — Environment Variables
# Copy this file to .env and fill in all values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────
# Full PostgreSQL connection string used by Prisma
DATABASE_URL="postgresql://zenda:zenda@localhost:5433/zenda?schema=public"

# Individual vars used by docker-compose.yml
POSTGRES_DB=zenda
POSTGRES_USER=zenda
POSTGRES_PASSWORD=zenda
POSTGRES_PORT=5433

# ── App ───────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_NAME="ZENDA API"

# ── Auth (JWT) ────────────────────────────────────────────────────
# Must be at least 32 random characters in production
JWT_SECRET="replace-with-a-secure-random-string-of-at-least-32-chars"
# Token lifetime — roadmap requires 30 days (US-0102)
JWT_EXPIRES_IN="30d"
BCRYPT_ROUNDS=12

# ── Azure OpenAI (Phase 8 — AI Predictions) ───────────────────────
AZURE_OPENAI_ENDPOINT="https://your-resource.openai.azure.com/"
AZURE_OPENAI_KEY="replace-with-azure-openai-key"

# ── Firebase Cloud Messaging (Phase 11 — Push Notifications) ──────
FCM_SERVER_KEY="replace-with-fcm-server-key"
