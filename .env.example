# ─────────────────────────────────────────────────────────────────
# Zenda Backend — Environment Variables
# Copy this file to .env and fill in all values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────
# Full PostgreSQL connection string used by Prisma
DATABASE_URL="postgresql://zenda:zenda@localhost:5433/zenda?schema=public"

# Individual vars used by docker-compose.yml
POSTGRES_DB=zenda
POSTGRES_USER=zenda
POSTGRES_PASSWORD=zenda
POSTGRES_PORT=5433

# ── App ───────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_NAME="ZENDA API"
JWT_SECRET="replace-with-secure-secret"
JWT_EXPIRES_IN="30d"
BCRYPT_ROUNDS=12

# ── Azure OpenAI (Phase 8 — AI Predictions) ───────────────────────
AZURE_OPENAI_ENDPOINT="https://your-resource.openai.azure.com/"
AZURE_OPENAI_KEY="replace-with-azure-openai-key"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="Zenda <noreply@zenda.app>"
