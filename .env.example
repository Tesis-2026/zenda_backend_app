# ─────────────────────────────────────────────────────────────────
# Zenda Backend — Environment Variables
# Copy this file to .env and fill in all values.
# NEVER commit .env to version control.
# Generate JWT_SECRET with: node -e "require('crypto').randomBytes(48).toString('hex')|console.log"
# ─────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL="postgresql://<user>:<password>@localhost:5433/zenda?schema=public"

POSTGRES_DB=zenda
POSTGRES_USER=zenda
POSTGRES_PASSWORD=<strong-random-password>
POSTGRES_PORT=5433

# ── App ───────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_NAME="ZENDA API"

# ── Auth ──────────────────────────────────────────────────────────
# Min 32 bytes (48+ recommended). Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="<replace-with-min-32-byte-hex-secret>"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_DAYS=7
BCRYPT_ROUNDS=12

# ── Azure OpenAI (Phase 7+ — AI Predictions, Recommendations, Auto-Categorization) ──
# Steps:
#   1. Go to portal.azure.com → Azure AI Foundry → Your project → Deployments
#   2. Copy "Target URI"  → paste into AZURE_OPENAI_ENDPOINT  (e.g. https://YOUR-RESOURCE.openai.azure.com/)
#   3. Copy "Primary Key" → paste into AZURE_OPENAI_KEY
#   4. Set AZURE_OPENAI_DEPLOYMENT to the model deployment name (e.g. gpt-4o-mini or phi-4-mini)
# The app works without these values (falls back to statistical predictions).
AZURE_OPENAI_ENDPOINT="https://your-resource.openai.azure.com/"
AZURE_OPENAI_KEY="replace-with-your-azure-openai-api-key-here"
AZURE_OPENAI_DEPLOYMENT="gpt-4o-mini"

# ── Email (SMTP) ──────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="Zenda <noreply@zenda.app>"
