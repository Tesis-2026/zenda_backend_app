generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum AccountType {
  CASH
  BANK_ACCOUNT
  DIGITAL_WALLET
  CREDIT_CARD
}

enum CategoryType {
  SYSTEM
  CUSTOM
}

enum IncomeType {
  SCHOLARSHIP
  PART_TIME
  FAMILY
  MIXED
}

enum FinancialLiteracyLevel {
  LOW
  MEDIUM
  HIGH
}

enum TopicDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum RecommendationType {
  SAVINGS
  BUDGET
  GOAL
}

enum SurveyType {
  PRE
  POST
  SUS
  SATISFACTION
}

enum NotificationType {
  TRANSACTION_RECORDED
  BUDGET_ALERT
  ANOMALY_ALERT
  PREDICTION_READY
  CHALLENGE_REMINDER
  DAILY_REMINDER
  BADGE_EARNED
}

enum FeedbackType {
  BUG
  SUGGESTION
  GENERAL
}

enum AiConversationStatus {
  ACTIVE
  CLOSED
}

enum AiMessageRole {
  USER
  ASSISTANT
}

// Source of a transaction's category assignment.
// AI            = AI suggested and the user accepted as-is
// AI_OVERRIDDEN = AI suggested but the user picked a different category
// USER          = user picked the category manually (no AI suggestion)
enum CategorySource {
  AI
  AI_OVERRIDDEN
  USER
}

enum AuditStatus {
  SUCCESS
  FAILURE
}

enum AuthChallengeKind {
  RESET_TOKEN
  OTP
}

// ─────────────────────────────────────────────────────────────────
// CORE MODELS
// ─────────────────────────────────────────────────────────────────

model User {
  id           String @id @default(uuid()) @db.Uuid
  email        String @unique
  passwordHash String
  fullName     String

  // Profile fields collected during onboarding (US-0105)
  age                    Int?
  university             String?
  incomeType             IncomeType?
  averageMonthlyIncome   Decimal?                @db.Decimal(12, 2)
  financialLiteracyLevel FinancialLiteracyLevel?
  profileCompleted       Boolean                 @default(false)
  currency               String                  @default("PEN")

  // Law 29733 consent (US-1303)
  consentGiven Boolean   @default(false)
  consentAt    DateTime?

  // Login lockout (US-0102)
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  // Monotonic counter bumped on password reset / global revoke.
  // Embedded as a claim in every issued JWT so the auth guard can
  // reject tokens minted before the latest version (B21/B25).
  tokenVersion Int @default(0)

  // Notification preferences inlined as JSON (was NotificationPreference table).
  // Shape: { BUDGET_ALERT: boolean, ANOMALY_ALERT: boolean, PREDICTION_READY: boolean,
  //          CHALLENGE_REMINDER: boolean, DAILY_REMINDER: boolean, BADGE_EARNED: boolean }
  // Missing keys default to true (opt-out behavior).
  notificationPrefs Json @default("{}")

  // FCM push token from Firebase Cloud Messaging. Null until the mobile app
  // registers a token via POST /api/notifications/fcm-token. Overwritten on
  // re-registration (single-device model for thesis scope).
  fcmToken          String?
  // Preferred local time-of-day for DAILY_REMINDER cron, "HH:mm" 24h format.
  // Null = use system default 20:00. Stored as string to avoid timezone math.
  dailyReminderAt   String?

  // Relations
  categories        Category[]
  accounts          Account[]
  transactions      Transaction[]
  savingsGoals      SavingsGoal[]
  budgets           Budget[]
  userTopicProgress UserTopicProgress[]
  quizAttempts      QuizAttempt[]
  userChallenges    UserChallenge[]
  userBadges        UserBadge[]
  predictions       Prediction[]
  recommendations   Recommendation[]
  surveyResponses   SurveyResponse[]
  analyticsEvents   AnalyticsEvent[]
  auditLogs         AuditLog[]
  feedbacks         Feedback[]
  authChallenges    AuthChallenge[]
  refreshTokens     RefreshToken[]
  aiConversations   AiConversation[]
  financialProgress UserFinancialProgress[]
  idempotencyKeys   IdempotencyKey[]
  notifications     Notification[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([email])
}

model Category {
  id              String           @id @default(uuid()) @db.Uuid
  name            String
  type            CategoryType     @default(CUSTOM)
  // Stable semantic icon key (e.g. "food", "transport") resolved to an
  // IconData on the client. null = no assigned icon; the client renders a
  // single default icon (used for CUSTOM categories — the name differentiates).
  icon            String?
  // null = usable for both; set when the category is type-specific
  transactionType TransactionType?
  userId          String?          @db.Uuid
  user            User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions             Transaction[] @relation("TransactionCategory")
  suggestedForTransactions Transaction[] @relation("TransactionSuggestedCategory")
  budgets         Budget[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([type, userId, deletedAt])
  @@index([name])
}

model Account {
  id             String      @id @default(uuid()) @db.Uuid
  userId         String      @db.Uuid
  name           String
  type           AccountType
  currency       String      @default("PEN")
  openingBalance Decimal     @default(0) @db.Decimal(12, 2)
  creditLimit    Decimal?    @db.Decimal(12, 2)
  institution    String?
  isDefault      Boolean     @default(false)

  user                    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceTransactions      Transaction[] @relation("TransactionSourceAccount")
  destinationTransactions Transaction[] @relation("TransactionDestinationAccount")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId, type, deletedAt])
  @@index([userId, isDefault])
}

model Transaction {
  id          String          @id @default(uuid()) @db.Uuid
  userId      String          @db.Uuid
  categoryId  String?         @db.Uuid
  accountId   String?         @db.Uuid
  toAccountId String?         @db.Uuid
  // Budget this transaction draws from (expense) or adds to (income). Chosen by
  // the user, independent of the category. Null = not linked to a budget.
  budgetId    String?         @db.Uuid
  type        TransactionType
  currency    String          @default("PEN")
  amount      Decimal         @db.Decimal(12, 2)
  description String
  occurredAt  DateTime        @default(now())

  // AI classification provenance (Esquema de Datos #5)
  // suggestedCategoryId: what the AI proposed at create time (preserved even if the user overrides)
  // aiConfidence: 0.00–1.00 from the AI provider
  // categorySource: derived from (suggestedCategoryId, categoryId) at create/update time
  suggestedCategoryId String?         @db.Uuid
  aiConfidence        Decimal?        @db.Decimal(3, 2)
  categorySource      CategorySource  @default(USER)

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category          Category? @relation("TransactionCategory", fields: [categoryId], references: [id], onDelete: SetNull)
  suggestedCategory Category? @relation("TransactionSuggestedCategory", fields: [suggestedCategoryId], references: [id], onDelete: SetNull)
  account           Account?  @relation("TransactionSourceAccount", fields: [accountId], references: [id], onDelete: SetNull)
  toAccount         Account?  @relation("TransactionDestinationAccount", fields: [toAccountId], references: [id], onDelete: SetNull)
  budget            Budget?   @relation(fields: [budgetId], references: [id], onDelete: SetNull)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId, occurredAt])
  @@index([userId, categoryId])
  @@index([userId, type, occurredAt])
  @@index([userId, categorySource])
  @@index([userId, accountId, occurredAt])
  @@index([userId, toAccountId, occurredAt])
  @@index([budgetId])
}

model SavingsGoal {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @db.Uuid
  name          String
  targetAmount  Decimal   @db.Decimal(12, 2)
  currentAmount Decimal   @default(0) @db.Decimal(12, 2)
  dueDate       DateTime?
  // Explicit completion timestamp. Distinguishes "user marked it done" from
  // "balance happens to equal target" (US-045 / ARCH-05).
  completedAt   DateTime?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  contributions GoalContribution[]

  @@index([userId])
}

model GoalContribution {
  id        String      @id @default(uuid()) @db.Uuid
  goalId    String      @db.Uuid
  amount    Decimal     @db.Decimal(12, 2)
  goal      SavingsGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@index([goalId])
}

// ─────────────────────────────────────────────────────────────────
// BUDGETS (Phase 6)
// ─────────────────────────────────────────────────────────────────

model Budget {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  categoryId  String?   @db.Uuid
  // User-given name for the budget "pot" (e.g. "Alquiler"), independent of the
  // category. Null falls back to the category label on the client.
  name        String?
  amountLimit Decimal   @db.Decimal(12, 2)
  month       Int
  year        Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  transactions Transaction[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // categoryId null = global budget; unique per user/category/period
  @@unique([userId, categoryId, month, year])
  @@index([userId, month, year])
}

// ─────────────────────────────────────────────────────────────────
// NOTIFICATIONS (Phase 11)
// Preferences live as JSON on User.notificationPrefs — see User model.
// ─────────────────────────────────────────────────────────────────

// ─────────────────────────────────────────────────────────────────
// EDUCATION & GAMIFICATION (Phase 10)
// ─────────────────────────────────────────────────────────────────

model EducationalTopic {
  id            String              @id @default(uuid()) @db.Uuid
  title         String
  content       String
  difficulty    TopicDifficulty     @default(BEGINNER)
  order         Int                 @default(0)
  // Thematic group for client iconography/colour: 'budgeting' | 'saving' | 'investing'.
  category      String              @default("budgeting")
  userProgress  UserTopicProgress[]
  quizQuestions QuizQuestion[]
  quizAttempts  QuizAttempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────
// QUIZ QUESTION POOL (US-1004)
// Bilingual, difficulty-tagged questions for in-app quizzes.
// EN and ES variants share a questionGroupKey so the backend can
// serve either language from the same pool.
// ─────────────────────────────────────────────────────────────────

model QuizQuestion {
  id               String            @id @default(uuid()) @db.Uuid
  topicId          String?           @db.Uuid
  questionGroupKey String // groups EN + ES variants of the same question
  language         String // 'en' or 'es'
  difficulty       TopicDifficulty
  text             String
  options          Json // String[]
  correctAnswer    String
  topic            EducationalTopic? @relation(fields: [topicId], references: [id], onDelete: SetNull)
  attempts         QuizAttempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([topicId, difficulty, language])
  @@index([questionGroupKey])
}

model UserTopicProgress {
  id            String           @id @default(uuid()) @db.Uuid
  userId        String           @db.Uuid
  topicId       String           @db.Uuid
  // Earned by passing the topic quiz (>=70%). Drives the literacy metric + badge.
  completedAt   DateTime?
  // Set when the user marks the topic as read — distinct from completion.
  readAt        DateTime?
  score         Decimal?         @db.Decimal(5, 2) // 0–100, latest quiz score for this topic
  attemptsCount Int              @default(0)
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic         EducationalTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, topicId])
  @@index([userId])
}

// Persisted per-attempt history for quizzes (US-1004).
// Enables tracking financial-literacy progress and the >=20% improvement KPI.
model QuizAttempt {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  questionId     String   @db.Uuid
  topicId        String?  @db.Uuid
  selectedAnswer String
  isCorrect      Boolean
  attemptedAt    DateTime @default(now())

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  question QuizQuestion      @relation(fields: [questionId], references: [id], onDelete: Cascade)
  topic    EducationalTopic? @relation(fields: [topicId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([userId, topicId, attemptedAt])
  @@index([userId, attemptedAt])
  @@index([questionId])
}

model Challenge {
  id             String          @id @default(uuid()) @db.Uuid
  title          String
  description    String
  criteriaJson   Json
  reward         String?
  // Gamification points awarded on completion (US-1002). Badge reward, when any,
  // is encoded in `reward` (e.g. "Insignia Constancia").
  pointsReward   Int             @default(0)
  userChallenges UserChallenge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Status (AVAILABLE / ACTIVE / COMPLETED) is derived from (acceptedAt, completedAt) — never stored.
// Domain rule: acceptedAt = null → AVAILABLE · acceptedAt set + completedAt null → ACTIVE · completedAt set → COMPLETED.
model UserChallenge {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  challengeId String    @db.Uuid
  acceptedAt  DateTime?
  completedAt DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, challengeId])
  @@index([userId, completedAt])
  @@index([userId, acceptedAt])
}

model Badge {
  id          String      @id @default(uuid()) @db.Uuid
  name        String      @unique
  description String
  criteria    String
  iconUrl     String?
  userBadges  UserBadge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserBadge {
  id       String   @id @default(uuid()) @db.Uuid
  userId   String   @db.Uuid
  badgeId  String   @db.Uuid
  earnedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────
// AI / ML (Phase 8–9)
// ─────────────────────────────────────────────────────────────────

model Prediction {
  id                  String          @id @default(uuid()) @db.Uuid
  userId              String          @db.Uuid
  period              String // Format: "YYYY-MM", e.g. "2026-04"
  type                TransactionType
  predictedTotal      Decimal         @db.Decimal(12, 2)
  predictedByCategory Json? // Array of { categoryId, categoryName, amount }
  confidenceInterval  Json? // { lower: number, upper: number } — derived from confidenceLevel + predictedTotal
  // Confidence + narrative used to be packed into `modelVersion` as
  // `"<version>|confidence:<level>|narrative:<text>"` (ARCH-04). B17
  // promoted them to proper columns so the API can return them cleanly
  // and so confidenceInterval can be derived without string parsing.
  confidenceLevel     String? // 'high' | 'medium' | 'low'
  narrative           String?
  modelVersion        String? // version identifier only — no longer packed
  actualTotal         Decimal?        @db.Decimal(12, 2) // filled after period ends
  accuracy            Decimal?        @db.Decimal(5, 2) // retrospective accuracy %
  user                User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, period, type])
  @@index([userId, period])
}

model Recommendation {
  id               String             @id @default(uuid()) @db.Uuid
  userId           String             @db.Uuid
  type             RecommendationType
  message          String
  suggestedAction  String?
  isActive         Boolean            @default(true)
  // Traceability for the AI-history KPI (>=80% prediction accuracy support)
  modelVersion     String? // e.g. "rules-v1" | "azure-foundry-gpt-4o-2024-08-06"
  source           String? // e.g. "local-rules" | "azure-foundry"
  inputContextJson Json? // snapshot of inputs used to generate (period totals, budgets…)
  // Lifecycle history
  viewedAt         DateTime?
  dismissedAt      DateTime?
  expiresAt        DateTime?
  // Inlined feedback (was previously RecommendationFeedback 1:1 table)
  feedbackAccepted Boolean?
  feedbackAt       DateTime?
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isActive])
  @@index([userId, createdAt])
  @@index([userId, dismissedAt])
}

// ─────────────────────────────────────────────────────────────────
// USER FINANCIAL PROGRESS — monthly behavioral snapshot
// Persists the user's learning trajectory across financial behavior
// and educational engagement, enabling longitudinal analysis and
// correlation between literacy gains and habit changes.
// ─────────────────────────────────────────────────────────────────

model UserFinancialProgress {
  id                       String   @id @default(uuid()) @db.Uuid
  userId                   String   @db.Uuid
  period                   String // "YYYY-MM"
  // Financial behavior
  budgetComplianceScore    Decimal? @db.Decimal(5, 2) // % categories within budget (0–100)
  savingsRatePct           Decimal? @db.Decimal(5, 2) // (income - expenses) / income * 100
  overspendCategoriesCount Int      @default(0)
  // Engagement with AI guidance
  recommendationsShown     Int      @default(0)
  recommendationsAccepted  Int      @default(0)
  // Educational engagement
  quizzesCompleted         Int      @default(0)
  avgQuizScore             Decimal? @db.Decimal(5, 2) // 0–100
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, period])
  @@index([userId, period])
}

// ─────────────────────────────────────────────────────────────────
// IMPACT EVALUATION — PRE/POST SURVEYS (Phase 12)
// ─────────────────────────────────────────────────────────────────

// Surveys embed their questions as JSON (was a separate SurveyQuestion table).
// questionsJson shape: SurveyQuestionJson[] (see src/modules/education/domain/survey-question.types.ts).
// Question keys are UUIDs preserved across migrations so SurveyResponse.answersJson references stay valid.
model Survey {
  id            String           @id @default(uuid()) @db.Uuid
  type          SurveyType
  questionsJson Json             @default("[]")
  responses     SurveyResponse[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SurveyResponse {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  surveyId    String   @db.Uuid
  answersJson Json // Map of questionId → selectedOption
  score       Decimal? @db.Decimal(5, 2) // 0–100
  completedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  survey      Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@unique([userId, surveyId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────
// ANALYTICS & AUDIT (Phase 13–15)
// ─────────────────────────────────────────────────────────────────

model AnalyticsEvent {
  id        String @id @default(uuid()) @db.Uuid
  userId    String @db.Uuid
  eventType String // e.g. "record_transaction", "view_prediction"
  metadata  Json?
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, eventType])
  @@index([createdAt])
}

model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  userId     String?     @db.Uuid // actor — who performed the action; null = system/cron
  action     String // e.g. "DELETE_ACCOUNT", "RESET_PASSWORD"
  resource   String // e.g. "User", "Transaction"
  resourceId String?     @db.Uuid // UUID of the specific resource affected
  status     AuditStatus @default(SUCCESS)
  requestId  String? // correlation id across logs in the same request
  httpMethod String? // GET, POST, PUT, DELETE…
  httpPath   String? // e.g. /api/transactions/:id
  ipAddress  String?
  userAgent  String?
  beforeJson Json? // state before the change
  afterJson  Json? // state after the change
  metadata   Json?
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, resource])
  @@index([resource, resourceId])
  @@index([requestId])
  @@index([createdAt])
}

// Unified auth challenges (was PasswordResetToken + PasswordResetOtp).
// secret stores the hashed token (RESET_TOKEN) or hashed OTP code (OTP).
// email is only used for OTP lookup by email; null for RESET_TOKEN.
model AuthChallenge {
  id        String            @id @default(uuid()) @db.Uuid
  userId    String            @db.Uuid
  kind      AuthChallengeKind
  secret    String // sha256 hash of the raw token or code
  email     String? // only set for OTP — enables findByEmail+code
  expiresAt DateTime
  usedAt    DateTime?
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime          @default(now())

  @@unique([kind, secret])
  @@index([userId, kind])
  @@index([email, kind])
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  token     String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model Feedback {
  id         String       @id @default(uuid()) @db.Uuid
  userId     String       @db.Uuid
  type       FeedbackType @default(GENERAL)
  message    String
  screenName String?
  rating     Int? // 1–5
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
}

// ─────────────────────────────────────────────────────────────────
// AI CHAT — CONVERSATIONAL ASSISTANT
// ─────────────────────────────────────────────────────────────────

model AiConversation {
  id        String               @id @default(uuid()) @db.Uuid
  userId    String               @db.Uuid
  status    AiConversationStatus @default(ACTIVE)
  startedAt DateTime             @default(now())
  endedAt   DateTime?            // set when the conversation is closed (e.g. on logout)
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  AiMessage[]

  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  // At most one ACTIVE conversation per user — enforced in the service layer
  // (Prisma cannot express a partial unique index in the schema).
  @@index([userId, status])
}

model AiMessage {
  id             String         @id @default(uuid()) @db.Uuid
  conversationId String         @db.Uuid
  role           AiMessageRole
  content        String
  feedbackRating Int?
  feedbackHelpful Boolean?
  feedbackClear Boolean?
  feedbackPersonalized Boolean?
  feedbackComment String?
  feedbackAt DateTime?
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt      DateTime       @default(now())

  @@index([conversationId, createdAt])
  @@index([feedbackAt])
}

// ─────────────────────────────────────────────────────────────────
// IDEMPOTENCY KEYS — B28
// Lets clients safely retry POST/PUT/PATCH after network failures
// without creating duplicate records.
//
// Lifecycle:
//   - Created on the first request with a given (key, userId).
//   - Looked up on every subsequent request with the same pair:
//       * matching requestHash       → return the cached response
//       * mismatched requestHash     → 409 (key reused for a different payload)
//   - Periodically pruned by a background job (TTL ~24h is the convention).
// ─────────────────────────────────────────────────────────────────

model IdempotencyKey {
  id           String   @id @default(uuid()) @db.Uuid
  key          String
  userId       String   @db.Uuid
  // sha256 of `${method} ${path}\n${normalized-body}` so the same key
  // cannot be reused for a different request shape.
  requestHash  String
  statusCode   Int
  responseBody Json
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([key, userId])
  @@index([createdAt])
}

// Persistent notification inbox. Every cron-fired or event-fired notification
// is written here and (best-effort) pushed via FCM. The inbox survives push
// failures so the user always sees the alert next time they open the app.
//
// `data` carries a small JSON payload routed back to the app for deep linking
// (e.g. { budgetId, categoryName } for BUDGET_ALERT).
model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  type      NotificationType
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  sentAt    DateTime?
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime         @default(now())

  // Inbox listing: newest first per user, filtered by read state.
  @@index([userId, createdAt])
  @@index([userId, readAt])
}
